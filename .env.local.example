# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# --- OpenAI ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# Options: gpt-4o-mini (fast/cheap), gpt-4o (best quality)
OPENAI_MODEL=gpt-4o-mini

# --- Supabase (add when ready) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never prefix with NEXT_PUBLIC_
